---
services:
  {{ app_name }}:
    image: "{{ docker_image }}:{{ docker_tag }}"
    container_name: "{{ app_name }}"
    ports:
      - "{{ app_port }}:{{ app_internal_port }}"
{% if web_app_environment | length > 0 %}
    environment:
{% for key, value in web_app_environment | dictsort %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
    restart: "{{ app_restart_policy }}"
    networks:
      - "{{ web_app_network_name }}"

networks:
  {{ web_app_network_name }}:
    driver: bridge
